{
  "name": "@lucascaro/pi-devkit",
  "version": "0.1.0",
  "description": "Lucas's Pi extensions, skills, prompt templates, and themes.",
  "keywords": ["pi-package", "pi", "coding-agent", "extensions", "skills"],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "extensions",
    "skills",
    "prompts",
    "themes",
    "src",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": ["./extensions"],
    "skills": ["./skills"],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "latest",
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typebox": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:skills": "tsx scripts/validate-skills.ts",
    "validate:themes": "tsx scripts/validate-themes.ts",
    "validate:prompts": "tsx scripts/validate-prompts.ts",
    "validate:extensions": "tsx scripts/validate-extensions.ts",
    "validate:pi-manifest": "tsx scripts/validate-pi-manifest.ts",
    "validate:files": "tsx scripts/validate-files.ts",
    "validate": "npm run validate:skills && npm run validate:themes && npm run validate:prompts && npm run validate:extensions && npm run validate:pi-manifest && npm run validate:files",
    "generate:catalog": "tsx scripts/generate-catalog.ts > docs/catalog.md",
    "check": "npm run typecheck && npm run validate && npm run test"
  }
}
